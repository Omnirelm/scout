# Copy this file to .env and fill in the values.
# Used by docker compose (env_file: ./orchestrator/.env) and local uv runs.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── GitHub MCP (optional) ─────────────────────────────────────────────────────
# Remote GitHub MCP endpoint; set a PAT in config.yaml under
# tools.mcp.github.headers.Authorization when enabling the GitHub tool.
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# ── Redis (optional — not required by the orchestrator core) ──────────────────
# If running Redis via compose, set REDIS_HOST to the service name (e.g. redis).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=drain3
REDIS_SSL=false

# ── Drain3 log deduplication (optional) ───────────────────────────────────────
DRAIN3_SIMILARITY_THRESHOLD=0.4
DRAIN3_MAX_DEPTH=4
DRAIN3_MAX_CHILDREN=100
DRAIN3_KEY_TTL_SECONDS=1800

# ── Analysis limits (optional) ────────────────────────────────────────────────
ANALYSIS_LOG_LIMIT=500

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=orchestrator
# When running with: docker compose --profile observability up
# set this to the Jaeger gRPC receiver inside the compose network:
#   OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=

# Disable OpenAI Agents SDK's own tracing when OTEL is active
OPENAI_AGENTS_DISABLE_TRACING=1

# ── Orchestrator overrides (optional) ─────────────────────────────────────────
# ORCHESTRATOR_DEBUG=false
# ORCHESTRATOR_LOG_LEVEL=INFO
